# ── AI / LLM ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=

# Models (override defaults)
CLAUDE_GM_MODEL=claude-sonnet-4-6
CLAUDE_SUMMARY_MODEL=claude-haiku-4-5-20251001

# ── Speech-to-Text ────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=
DEEPGRAM_PROJECT_ID=

# ── Embeddings ────────────────────────────────────────────────────────────────
VOYAGE_API_KEY=

# ── Infrastructure ────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/audio_rpg
REDIS_URL=redis://localhost:6379
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=audio-rpg

# ── API server (apps/api) ─────────────────────────────────────────────────────
PORT=4000
SESSION_SIGNING_KEY=change-me
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000

# ── Web app (apps/web) ────────────────────────────────────────────────────────
# Database variable is DATABASE_URL (shared by web + api).
# For web local dev, change DATABASE_URL above to: file:./dev.db
NEXTAUTH_SECRET=change-me-in-prod
NEXTAUTH_URL=http://localhost:3000

# Stripe (web payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STORYTELLER_MONTHLY=price_...
STRIPE_PRICE_STORYTELLER_ANNUAL=price_...
STRIPE_PRICE_CREATOR_MONTHLY=price_...
STRIPE_PRICE_CREATOR_ANNUAL=price_...

# RevenueCat (mobile payments)
REVENUECAT_APPLE_API_KEY=appl_...
REVENUECAT_GOOGLE_API_KEY=goog_...

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM=EchoQuest <noreply@echoquest.app>

# Admin access (comma-separated emails)
ADMIN_EMAILS=admin@echoquest.app

# Web Push (VAPID) — generate keys: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@echoquest.app
