{
  "name": "audio-rpg",
  "private": true,
  "version": "0.0.0",
  "description": "Accessibility-first audio RPG platform. Audible meets AI Game Master.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' --filter './apps/api' --filter './apps/web' build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "dev:api": "pnpm --filter @audio-rpg/api dev",
    "dev:mobile": "pnpm --filter @audio-rpg/mobile start",
    "dev:web": "pnpm --filter @audio-rpg/web dev",
    "security:audit:prod": "pnpm audit --prod --json",
    "security:release-gate": "node scripts/security-release-gate.mjs",
    "check:anthropic-sdk-version": "node scripts/check-anthropic-sdk-version.mjs",
    "check:parity-gate": "node scripts/check-platform-parity-gate.mjs"
  },
  "devDependencies": {
    "typescript": "5.5.4"
  },
  "pnpm": {
    "overrides": {
      "tar": "^7.5.13",
      "minimatch": "^9.0.9",
      "postcss": "^8.5.12",
      "send": "^1.2.1",
      "@xmldom/xmldom": "^0.8.13",
      "@anthropic-ai/sdk": "0.91.0"
    }
  }
}
