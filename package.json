{
  "name": "audio-rpg",
  "private": true,
  "version": "0.0.0",
  "description": "Accessibility-first audio RPG platform. Audible meets AI Game Master.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' --filter './apps/api' --filter './apps/web' build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm run test:unit && pnpm run test:integration && pnpm run test:e2e && pnpm run test:a11y",
    "dev:api": "pnpm --filter @audio-rpg/api dev",
    "dev:mobile": "pnpm --filter @audio-rpg/mobile start",
    "dev:web": "pnpm --filter @audio-rpg/web dev",
    "security:audit:prod": "pnpm audit --prod --json",
    "security:release-gate": "node scripts/security-release-gate.mjs",
    "test:unit": "pnpm --filter @audio-rpg/shared test && pnpm --filter @audio-rpg/gm-engine test && pnpm --filter @audio-rpg/api test:unit && pnpm --filter @audio-rpg/web test:unit",
    "test:integration": "pnpm --filter @audio-rpg/api test:integration",
    "test:e2e": "pnpm --filter @audio-rpg/mobile test:e2e",
    "test:a11y": "pnpm --filter @audio-rpg/mobile test:a11y"
  },
  "devDependencies": {
    "typescript": "5.5.4"
  },
  "pnpm": {
    "overrides": {
      "tar": "^7.5.13",
      "minimatch": "^9.0.9",
      "postcss": "^8.5.12",
      "send": "^1.2.1",
      "@xmldom/xmldom": "^0.8.13"
    }
  }
}
