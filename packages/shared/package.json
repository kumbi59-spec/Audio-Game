{
  "name": "@audio-rpg/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "node": "./dist/index.js",
      "browser": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./gm": {
      "types": "./src/gm.ts",
      "node": "./dist/gm.js",
      "browser": "./dist/gm.js",
      "default": "./src/gm.ts"
    },
    "./bible": {
      "types": "./src/bible.ts",
      "node": "./dist/bible.js",
      "browser": "./dist/bible.js",
      "default": "./src/bible.ts"
    },
    "./events": {
      "types": "./src/events.ts",
      "node": "./dist/events.js",
      "browser": "./dist/events.js",
      "default": "./src/events.ts"
    },
    "./state": {
      "types": "./src/state.ts",
      "node": "./dist/state.js",
      "browser": "./dist/state.js",
      "default": "./src/state.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "3.25.76"
  },
  "devDependencies": {
    "typescript": "5.5.4",
    "vitest": "2.1.9"
  }
}
