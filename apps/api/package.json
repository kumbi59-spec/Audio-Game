{
  "name": "@audio-rpg/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/server.ts",
  "scripts": {
    "dev": "pnpm --filter @audio-rpg/shared --filter @audio-rpg/gm-engine build && tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json && cp src/state/schema.sql dist/state/schema.sql",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "tsx scripts/e2e.ts",
    "pretest": "pnpm --filter @audio-rpg/shared --filter @audio-rpg/gm-engine build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.91.0",
    "@audio-rpg/gm-engine": "workspace:*",
    "@audio-rpg/shared": "workspace:*",
    "@fastify/cors": "11.2.0",
    "@fastify/multipart": "10.0.0",
    "@fastify/websocket": "11.2.0",
    "fastify": "5.8.5",
    "mammoth": "1.12.0",
    "pdf-parse": "1.1.1",
    "pg": "8.13.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/pdf-parse": "1.1.4",
    "@types/pg": "8.11.10",
    "@types/ws": "8.5.12",
    "tsx": "4.19.1",
    "typescript": "5.5.4",
    "vitest": "2.1.9",
    "ws": "8.18.0"
  }
}
