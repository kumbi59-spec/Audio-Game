# EchoQuest production env template.
#
# Copy values into your hosting provider's secret store (Render dashboard,
# Vercel project settings, Fly secrets, etc). NEVER commit a populated copy.
#
# Two services consume this:
#   - apps/web (Next.js) needs the WEB block + ANTHROPIC_API_KEY + DATABASE_URL
#   - apps/api (Fastify) needs the API block + ANTHROPIC_API_KEY + DATABASE_URL
#
# DATABASE_URL points at a Supabase Postgres with the pgvector extension enabled.
# See DEPLOY.md for the full setup walkthrough.

# ── Shared ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# Use the Supabase POOLED connection string (port 6543) for the web app, and
# the DIRECT connection string (port 5432) for the api service. Both reach
# the same database; pooler avoids serverless connection-storm issues for
# Next.js, and the api needs a direct connection for pgvector + LISTEN/NOTIFY.
DATABASE_URL=

CLAUDE_GM_MODEL=claude-sonnet-4-6
CLAUDE_SUMMARY_MODEL=claude-haiku-4-5-20251001

# ── Web (apps/web) ───────────────────────────────────────────────────────────
NEXTAUTH_URL=https://echoquest-web.onrender.com
NEXTAUTH_SECRET=                    # 32-byte random; generate with `openssl rand -base64 32`
ADMIN_EMAILS=                       # comma-separated; these accounts get permanent Creator + /admin

# Stripe (live keys for production; webhook secret comes from `stripe listen` or dashboard)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STORYTELLER_MONTHLY=
STRIPE_PRICE_STORYTELLER_ANNUAL=
STRIPE_PRICE_CREATOR_MONTHLY=
STRIPE_PRICE_CREATOR_ANNUAL=

# Email (Resend; the FROM domain must be verified in the Resend dashboard)
RESEND_API_KEY=
RESEND_FROM=EchoQuest <noreply@yourdomain.com>

# Web Push (generate locally: `npx web-push generate-vapid-keys`)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@yourdomain.com

# ElevenLabs (premium voices)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_NARRATOR=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_A=AZnzlk1XvdvUeBnXmlld
ELEVENLABS_VOICE_B=VR6AewLTigWG4xSOukaG
ELEVENLABS_VOICE_C=pNInz6obpgDQGcFmaJgB

# ── API (apps/api) ───────────────────────────────────────────────────────────
PORT=4000
SESSION_SIGNING_KEY=                # 32-byte random; rotate independently of NEXTAUTH_SECRET
ALLOWED_ORIGINS=https://echoquest-web.onrender.com

REDIS_URL=                          # optional; falls back to in-memory if blank

# Speech-to-text + embeddings + asset storage (all optional)
DEEPGRAM_API_KEY=
DEEPGRAM_PROJECT_ID=
VOYAGE_API_KEY=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
